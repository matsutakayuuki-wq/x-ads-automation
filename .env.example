# App
APP_NAME=X Ads Automation
DEBUG=false
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Database
# Local: sqlite:///./data/x_ads_automation.db
# Railway: postgresql://... (auto-set by Railway PostgreSQL plugin)
DATABASE_URL=sqlite:///./data/x_ads_automation.db

# Security - Fernet key for credential encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Session signing secret
SECRET_KEY=change-me-in-production

# Admin usernames (comma-separated)
ADMIN_USERNAMES=
